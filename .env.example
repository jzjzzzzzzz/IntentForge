# ── Optional LLM Intent Translation ──────────────────────────────────
# Set these to enable LLM-based prompt and edit translation.
# Without these, the deterministic parser is used exclusively.
#
# Supported providers: openai-compatible, mock
# Compatible services: OpenAI, DeepSeek, Moonshot, Qwen, Baichuan, etc.

# Provider type: "openai-compatible" or "mock"
INTENTFORGE_LLM_PROVIDER=

# Base URL for the chat completions endpoint.
# The provider appends /chat/completions to this URL.
# Examples:
#   OpenAI:    https://api.openai.com/v1
#   DeepSeek:  https://api.deepseek.com/v1
#   Moonshot:  https://api.moonshot.cn/v1
#   Qwen:      https://dashscope.aliyuncs.com/compatible-mode/v1
INTENTFORGE_LLM_BASE_URL=

# Model name for the provider.
# Examples: gpt-4o-mini, deepseek-chat, moonshot-v1-8k, qwen-turbo
INTENTFORGE_LLM_MODEL=

# API key for the provider.
INTENTFORGE_LLM_API_KEY=
